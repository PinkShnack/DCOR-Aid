      <property name="text">
       <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;That archiving process is complete.&lt;/p&gt;&lt;p&gt;If you wish you can now validate the archive with the BagIt Python implementation:&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-family:'Hack';&quot;&gt;      pip install bagit &lt;br/&gt;      bagit.py --validate --quiet target_path/0*&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
      </property>
